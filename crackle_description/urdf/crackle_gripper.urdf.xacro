<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro" name="three_claw_gripper" >
  <xacro:macro name="three_claw_gripper" params="arm_link:='link_6'">

  <!-- Common properties -->
  <xacro:property name="pkg_path" value="package://crackle_description/meshes"/>
  <xacro:property name="mesh_scale" value="1 1 1"/>
  <!-- The lateral_rack_pinion_gripper mesh is authored in millimetres; scale to metres. -->
  <xacro:property name="mm_scale" value="0.001 0.001 0.001"/>
  <xacro:property name="arm_last_link" value="${arm_link}"/>

  <!-- Placement of the gripper mesh within the gripper_base link.
       In the raw mesh the rack/pinion mechanism sits at one end (mesh Z=-196mm)
       and the two fingers at the other (mesh Z=+38mm), with the lateral rack
       running along mesh X. This transform mounts the mechanism end on the
       flange (link origin) and points the fingers out along +Z (the arm's
       approach direction), with the rack opening along Y. The 90° yaw turns
       the rack from mesh X onto Y. -->
  <xacro:property name="gripper_mesh_xyz" value="-0.002 0.020 0.196"/>
  <xacro:property name="gripper_mesh_rpy" value="0 0 1.5708"/>

  <!-- Lateral rack (jaw) travel, in metres, from fully open (0) to fully closed. -->
  <xacro:property name="rack_travel" value="0.04"/>
  <!-- Where the jaws sit relative to the base origin: near the finger tips
       (+Z) and offset laterally along Y. -->
  <xacro:property name="jaw_z" value="0.19"/>
  <xacro:property name="jaw_open_y" value="0.05"/>

  <!-- =========================
       Macro: Gripper Base Link
       ========================= -->
  <xacro:macro name="gripper_base_macro" params="link_name base_mesh:='lateral_rack_pinion_gripper.stl'">
    <link name="${link_name}">
      <visual>
        <origin xyz="${gripper_mesh_xyz}" rpy="${gripper_mesh_rpy}"/>
        <geometry>
          <mesh filename="${pkg_path}/${base_mesh}" scale="${mm_scale}"/>
        </geometry>
        <material name="gripper_blue">
          <color rgba="0.0 0.0 0.5 1"/>
        </material>
      </visual>
      <!-- Collision geometry so MoveIt actually sees the gripper body and stops
           plans that would drive it through the table (or other obstacles). Uses
           the same STL + transform as the visual, so the collision model matches
           exactly what you see, INCLUDING the open gap between the fingers (so a
           target object can still fit between them). -->
      <collision>
        <origin xyz="${gripper_mesh_xyz}" rpy="${gripper_mesh_rpy}"/>
        <geometry>
          <mesh filename="${pkg_path}/${base_mesh}" scale="${mm_scale}"/>
        </geometry>
      </collision>
    </link>

    <!-- ===== Left rack (jaw) =====
         Visual only, NO collision: the racks are moving (prismatic) jaws that
         close around the grasped object, so leaving them collidable just trips
         false object/table collisions during grasp and lift. The gripper_base
         mesh already provides the gripper body's collision geometry. -->
    <link name="left_rack">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.02 0.01 0.04"/>
        </geometry>
        <material name="rack_grey">
          <color rgba="0.3 0.3 0.3 1"/>
        </material>
      </visual>
    </link>

    <!-- ===== Right rack (jaw) ===== visual only, NO collision (see left_rack). -->
    <link name="right_rack">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.02 0.01 0.04"/>
        </geometry>
        <material name="rack_grey">
          <color rgba="0.3 0.3 0.3 1"/>
        </material>
      </visual>
    </link>

    <!-- Rack (jaw) joints: PRISMATIC, driven symmetrically by the two pinion
         servos. Position 0 = fully open, ${rack_travel} = fully closed; both
         racks share the same (positive) value and close inward along ∓Y.
         A movable joint has no TF until its position is published on
         /joint_states, so claw_degree_publisher MUST publish these joints
         continuously (publish_joint_states=true, defaulting to 0.0/open even
         before the ESP32 streams). Without that, TF (world->left_rack) and
         MoveIt's current-state monitor go incomplete and planning fails. -->
    <joint name="left_rack_joint" type="prismatic">
      <parent link="${link_name}"/>
      <child link="left_rack"/>
      <origin xyz="0 ${jaw_open_y} ${jaw_z}" rpy="0 0 0"/>
      <axis xyz="0 -1 0"/>
      <limit lower="0.0" upper="${rack_travel}" effort="10.0" velocity="0.1"/>
    </joint>

    <joint name="right_rack_joint" type="prismatic">
      <parent link="${link_name}"/>
      <child link="right_rack"/>
      <origin xyz="0 ${-jaw_open_y} ${jaw_z}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="0.0" upper="${rack_travel}" effort="10.0" velocity="0.1"/>
    </joint>

  </xacro:macro>

  <!-- =========================
       Instantiate the Gripper
       ========================= -->

  <!-- 1) Base link -->
  <xacro:gripper_base_macro link_name="gripper_base"/>

  <!-- 2) Fixed joint to arm. The mesh transform above already puts the mount
       face at the gripper_base origin with the fingers along +Z, so the
       gripper mounts flush on the flange. Adjust the yaw here to clock the
       gripper about the tool axis if the jaw-opening direction needs rotating. -->
  <joint name="gripper_base_joint" type="fixed">
    <parent link="${arm_last_link}"/>
    <child link="gripper_base"/>
    <origin xyz="0.015 0.001 0.0" rpy="0 0 0"/>
  </joint>

  <link name="camera_depth_optical_frame">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="${pkg_path}/realsense_d435i.stl" scale="${mesh_scale}"/>
      </geometry>
      <material name="blue">
        <color rgba="0.5 0.0 0.0 1"/>
      </material>
    </visual>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0"
               izz="0.001"/>
    </inertial>
  </link>
<!--"0.02 0.02 0.05" -->
  <joint name="camera_depth_optical_frame_joint" type="fixed">
    <parent link="gripper_base"/>
    <child link="camera_depth_optical_frame"/>
     <origin xyz="0.05 -0.005 0.057" rpy=".2 -.08 -1.57"/>
    <!-- <origin xyz="0.03810 0.03504 -0.02364" rpy="0.05900 -0.00253 -1.60644"/> -->
  </joint>

  </xacro:macro> 

</robot>
